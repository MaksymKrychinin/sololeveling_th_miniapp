# Database
POSTGRES_DB=solo_leveling
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/solo_leveling

# Redis
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379
REDIS_URL=redis://:your_redis_password_here@localhost:6379

# API
API_PORT=3001
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
JWT_EXPIRES_IN=7d
API_URL=http://localhost:3001

# Web App
WEB_PORT=3000
VITE_API_URL=http://localhost:3001
VITE_TELEGRAM_BOT_NAME=YourBotName

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_WEBHOOK_URL=https://yourdomain.com/webhook

# Environment
NODE_ENV=development

# Monitoring (Optional)
SENTRY_DSN=
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
