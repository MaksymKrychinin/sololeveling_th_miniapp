# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solo_leveling_dev
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For Docker: postgresql://postgres:postgres@localhost:5432/solo_leveling_dev
# For Supabase: Get from Supabase Dashboard → Settings → Database → Connection string
# For Railway: Will be auto-populated from connected PostgreSQL service

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379
# Format: redis://HOST:PORT or redis://default:PASSWORD@HOST:PORT
# For Docker: redis://localhost:6379
# For Upstash: rediss://default:PASSWORD@HOST:6379
# For Railway: Will be auto-populated from connected Redis service

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-change-this
# Generate: openssl rand -base64 32
# IMPORTANT: Change this to a random 32+ character string
JWT_EXPIRATION=7d

# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ-replace-this
# Get from: https://t.me/BotFather
# Steps: 1) Open @BotFather 2) Send /newbot 3) Follow instructions 4) Copy token

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ============================================
# CORS (Frontend URL)
# ============================================
CORS_ORIGIN=http://localhost:3000
# Production: Set to your Vercel/Netlify URL
# Example: https://your-app.vercel.app

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
# These should be set in apps/web/.env for local development
# Or in Vercel/Netlify dashboard for production

# VITE_API_URL=http://localhost:3001
# Production: Your Railway/Render API URL
# Example: https://your-api.railway.app

# VITE_TELEGRAM_BOT_USERNAME=your_bot_username
# Your bot username without @ symbol
# Example: solo_leveling_bot

# ============================================
# OPTIONAL - MONITORING & LOGGING
# ============================================
# SENTRY_DSN=
# LOG_LEVEL=info

# ============================================
# OPTIONAL - RATE LIMITING
# ============================================
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100

